# ============================================================================
# .env.example — Backend (FastAPI) ortam değişkenleri
# Kurulum: `cp .env.example .env` (make setup bunu otomatik yapar)
# GERÇEK .env ASLA repo'ya girmez (.gitignore).
# ============================================================================

# --- Hedef (target) MES API — case study Bölüm 5.5 ---
# Tam dokümantasyon: http://89.252.189.91:8983/docs-guide
TARGET_API_URL=http://89.252.189.91:8983
TARGET_API_SUBMIT_PATH=/api/v1/submit
TARGET_API_KEY=buraya-production-key-gelecek
TARGET_API_TIMEOUT_SECONDS=15
TARGET_API_MAX_RETRIES=3
TARGET_API_BACKOFF_BASE_SECONDS=2
# 429 (rate limit) durumunda beklenecek süre
TARGET_API_RATE_LIMIT_COOLDOWN_SECONDS=60

# --- Uygulama ---
APP_ENV=development
LOG_LEVEL=INFO
# İlk açılışta data/production_data.csv otomatik seed edilsin mi (1=evet, 0=hayır)
AUTO_SEED=1

# --- Veritabanı (SQLite — zorunlu) ---
# Varsayılan: repo kökündeki db/app.db (config.py mutlak yolu hesaplar, set gerekmez).
# Override etmek istersen aşağıyı aç:
# DATABASE_URL=sqlite:///./db/app.db

# --- CORS (frontend origin) ---
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Frontend (Next.js) — yalnız NEXT_PUBLIC_* tarayıcıya sızar ---
# Boş bırak → tarayıcı relative /api/v1 çağırır, Next.js same-origin proxy'ler (CORS gerekmez).
# NEXT_PUBLIC_API_URL=
# Next.js rewrites() proxy hedefi (sunucu tarafı; tarayıcıya sızmaz).
BACKEND_INTERNAL_URL=http://localhost:8000
