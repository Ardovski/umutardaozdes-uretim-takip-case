# ============================================================================
# .gitignore — monorepo (Python backend + Next.js frontend)
# ============================================================================

# --- Secrets (ASLA commit etme) ---
.env
.env.*
!.env.example
!*/.env.example
!*/.env.local.example

# --- Python / FastAPI ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# --- Runtime SQLite DB (db/app.db gitignore'lu; db/README.md commit EDİLİR) ---
*.db
*.sqlite
*.sqlite3

# --- Node / Next.js ---
node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- AI asistan (kişisel/yerel ayarlar) ---
.claude/settings.local.json

# --- OS / IDE ---
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# --- Geçici / log ---
*.log
tmp/
.tmp/
