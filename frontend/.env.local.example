# Frontend ortam değişkenleri — apps/web/.env.local
# DİKKAT: NEXT_PUBLIC_* tarayıcıya gömülür → ASLA secret koyma (hedef API key SADECE backend'de).
#
# Varsayılan (bu dosya kopyalanmasa bile): client "/api/v1/..." çağırır ve Next
# rewrite bunu BACKEND_INTERNAL_URL'e proxy'ler → CORS gerekmez, sıfır-config çalışır.

# (opsiyonel) Doğrudan cross-origin bağlanmak istersen aç; proxy yerine bu kullanılır:
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Dev proxy hedefi — /api/v1/* rewrite'ın yönlendireceği FastAPI adresi
BACKEND_INTERNAL_URL=http://localhost:8000
