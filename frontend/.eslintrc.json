{
  "root": true,
  "extends": ["next/core-web-vitals"],
  "parser": "@typescript-eslint/parser",
  "plugins": ["boundaries", "@typescript-eslint"],
  "settings": {
    "import/resolver": { "typescript": { "project": "tsconfig.json" } },
    "boundaries/elements": [
      { "type": "app", "pattern": "src/app", "mode": "folder" },
      { "type": "feature", "pattern": "src/features/*", "mode": "folder", "capture": ["featureName"] },
      { "type": "ui", "pattern": "src/components/ui", "mode": "folder" },
      { "type": "atoms", "pattern": "src/components/atoms", "mode": "folder" },
      { "type": "molecules", "pattern": "src/components/molecules", "mode": "folder" },
      { "type": "organisms", "pattern": "src/components/organisms", "mode": "folder" },
      {
        "type": "shared",
        "pattern": ["src/lib", "src/hooks", "src/stores", "src/types"],
        "mode": "folder"
      }
    ],
    "boundaries/ignore": ["**/*.test.*", "**/*.spec.*", "**/*.config.*"]
  },
  "rules": {
    "boundaries/element-types": [
      "error",
      {
        "default": "disallow",
        "message": "Mimari sınır ihlali: katman yönü (ui/atoms → molecules → organisms → feature → app) tersinmez; feature'lar birbirini import edemez; ortak kod shared/ui/atoms/molecules/organisms'a taşınmalı.",
        "rules": [
          { "from": ["app"], "allow": ["app", "feature", "ui", "atoms", "molecules", "organisms", "shared"] },
          { "from": ["feature"], "allow": ["ui", "atoms", "molecules", "organisms", "shared", ["feature", { "featureName": "${from.featureName}" }]] },
          { "from": ["organisms"], "allow": ["ui", "atoms", "molecules", "organisms", "shared"] },
          { "from": ["molecules"], "allow": ["ui", "atoms", "molecules", "shared"] },
          { "from": ["atoms", "ui"], "allow": ["ui", "atoms", "shared"] },
          { "from": ["shared"], "allow": ["shared"] }
        ]
      }
    ],
    "import/no-cycle": ["error", { "maxDepth": 1 }],
    "@typescript-eslint/no-explicit-any": "error",
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          { "name": "next/router", "message": "App Router'da 'next/navigation' kullan (next/router değil)." }
        ],
        "patterns": [
          {
            "group": ["@/features/*/*", "../*/features/*", "../../features/*"],
            "message": "Feature içine derin import yok. Public API (@/features/<ad>) üzerinden veya 'shared' kullan."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "error",
      {
        "selector": "MemberExpression[object.object.name='process'][object.property.name='env']",
        "message": "process.env'e doğrudan erişme; tek nokta '@/lib/env' kullan (secret koruması + tip)."
      }
    ]
  },
  "overrides": [
    { "files": ["src/lib/env.ts"], "rules": { "no-restricted-syntax": "off" } },
    { "files": ["src/lib/logger.ts"], "rules": { "no-console": "off" } },
    {
      "files": ["src/app/**", "*.config.*", "next.config.mjs"],
      "rules": { "no-restricted-imports": "off" }
    }
  ]
}
